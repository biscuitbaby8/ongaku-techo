{
  "version": 2,
  "headers": [
    {
      "source": "/ads.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/term/:path*",
      "destination": "/term/:path*/index.html"
    },
    {
      "source": "/index/:path*",
      "destination": "/index/:path*/index.html"
    },
    {
      "source": "/index",
      "destination": "/index/index.html"
    }
  ]
}